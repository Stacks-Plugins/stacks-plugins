{
  "id": "stacks",
  "name": "Stacks Plugin",
  "description": "Stacks blockchain tools: balances, STX transfers, account history, stacking/PoX, BNS naming, Clarity contract calls, ALEX swaps, bridging, sBTC peg-in/out, and Zest yield.",
  "activation": {
    "onStartup": true
  },
  "configSchema": {
    "type": "object",
    "properties": {
      "defaultNetwork": {
        "anyOf": [
          {
            "type": "string",
            "const": "mainnet"
          },
          {
            "type": "string",
            "const": "testnet"
          }
        ],
        "description": "Default Stacks network when a tool omits `network`."
      }
    }
  },
  "version": "0.1.0",
  "contracts": {
    "tools": [
      "stacks_wallet_info",
      "stacks_get_balance",
      "stacks_send_tokens",
      "stacks_get_account_history",
      "stacks_stacking_status",
      "stacks_can_stack",
      "stacks_stack",
      "stacks_delegate_stx",
      "stacks_revoke_delegate",
      "stacks_resolve_name",
      "stacks_lookup_address",
      "stacks_get_name_price",
      "stacks_transfer_name",
      "stacks_contract_call",
      "stacks_read_only_call",
      "stacks_decode_cv",
      "stacks_swap_quote",
      "stacks_swap_execute",
      "stacks_bridge_quote",
      "stacks_bridge_initiate",
      "stacks_sbtc_get_balance",
      "stacks_send_sbtc",
      "stacks_sbtc_build_peg_in",
      "stacks_sbtc_initiate_peg_in",
      "stacks_sbtc_initiate_peg_out",
      "stacks_sbtc_get_peg_status",
      "stacks_zest_sbtc_vault_info",
      "stacks_zest_protocol_status",
      "stacks_zest_supply_sbtc",
      "stacks_zest_redeem_sbtc",
      "stacks_zest_position",
      "stacks_zest_collateral_add_sbtc",
      "stacks_zest_borrow",
      "stacks_zest_repay"
    ]
  },
  "toolMetadata": {
    "stacks_send_tokens": {
      "optional": true
    },
    "stacks_stack": {
      "optional": true
    },
    "stacks_delegate_stx": {
      "optional": true
    },
    "stacks_revoke_delegate": {
      "optional": true
    },
    "stacks_transfer_name": {
      "optional": true
    },
    "stacks_contract_call": {
      "optional": true
    },
    "stacks_swap_execute": {
      "optional": true
    },
    "stacks_bridge_initiate": {
      "optional": true
    },
    "stacks_send_sbtc": {
      "optional": true
    },
    "stacks_sbtc_initiate_peg_in": {
      "optional": true
    },
    "stacks_sbtc_initiate_peg_out": {
      "optional": true
    },
    "stacks_zest_supply_sbtc": {
      "optional": true
    },
    "stacks_zest_redeem_sbtc": {
      "optional": true
    },
    "stacks_zest_collateral_add_sbtc": {
      "optional": true
    },
    "stacks_zest_borrow": {
      "optional": true
    },
    "stacks_zest_repay": {
      "optional": true
    }
  }
}
