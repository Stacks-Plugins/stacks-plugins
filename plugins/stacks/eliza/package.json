    "@stacks/agent-core": "0.1.0"
  },
  "peerDependencies": {
    "@elizaos/core": ">=0.1.0"
  },
  "devDependencies": {
    "@elizaos/core": "^0.1.9",
    "typescript": "^5.9.3"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0"
  },
  "keywords": ["elizaos", "plugin", "stacks", "blockchain", "agent"]
